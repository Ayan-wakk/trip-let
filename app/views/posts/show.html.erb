<div class="w-screen sm:max-w-7xl mx-auto px-0 sm:px-6 sm:py-12 mt-6 rounded-3xl border border-gray-200 shadow-inner"
     style="background-color: #ffffff;
            background-image:
              linear-gradient(rgba(120, 110, 100, 0.15) 1px, transparent 1px),
              linear-gradient(90deg, rgba(120, 110, 100, 0.15) 1px, transparent 1px);
            background-size: 1.5rem 1.5rem;">
  
  <div class="flex flex-col sm:flex-row gap-0 sm:gap-10 items-start">

    <!-- 左：画像エリア -->
    <% if @post.images.attached? %>
      <div class="sm:w-3/5">

        <!-- メイン画像  -->
        <div class="relative mx-auto w-full sm:w-fit sm:rotate-[-2deg]">
         <% main_image = @post.images.first %>
         <% if main_image.variable? %>
          <%= image_tag main_image.variant(resize_to_limit: [800, 800]).processed,
                id: "main-image",
                loading: "eager",
                decoding: "async",
                class: "w-full sm:w-auto max-h-[400px] sm:max-h-[520px] object-contain bg-white sm:p-5
                        rounded-sm border border-gray-200 shadow-[0_12px_30px_rgba(0,0,0,0.25)]" %>
          <% else %>
            <%= image_tag main_image, 
                id: "main-image",
                loading: "eager",
                decoding: "async",
                class: "w-full sm:w-auto max-h-[400px] sm:max-h-[520px] object-contain bg-white sm:p-5
                        rounded-sm border border-gray-200 shadow-[0_12px_30px_rgba(0,0,0,0.25)]" %>
          <% end %>

          <!-- マスキングテープ -->
          <span class="hidden sm:block absolute -top-5 left-1/2 -translate-x-1/2
                       w-50 h-9
                       rotate-[-2deg]
                       z-20
                       rounded-[4px]
                       opacity-95
                       bg-[#c3d2a4]
                       shadow-[0_3px_6px_rgba(0,0,0,0.22)]
                       before:absolute before:inset-0
                       before:bg-[repeating-linear-gradient(
                       -45deg,
                       rgba(255,255,255,0.2),
                       rgba(255,255,255,0.2)_2px,
                       transparent_2px,
                       transparent_4px
                       )]
                       before:rounded-[4px]
                       after:absolute after:inset-0
                       after:border after:border-white/25
                       after:rounded-[4px]
                       ">
           </span>

          <!-- 左矢印 -->
          <button
            id="prev-image"
            class="absolute left-2 top-1/2 -translate-y-1/2
                   bg-white/80 hover:bg-white rounded-full p-2 shadow">
          ◀
          </button>

          <!-- 右矢印 -->
          <button
            id="next-image"
            class="absolute right-2 top-1/2 -translate-y-1/2
                   bg-white/80 hover:bg-white rounded-full p-2 shadow">
          ▶
          </button>
        </div>

        <!-- サムネイル -->
        <div class="sm:mt-12 flex gap-0 sm:gap-2 overflow-x-auto">
          <% @post.images.each_with_index do |image, index| %>
            <% if image.variable? %>
              <% thumb = image.variant(resize_to_fill: [200, 200]).processed %>
              <% main = image.variant(resize_to_limit: [800, 800]).processed %>
              <%= image_tag thumb,
                class: "thumbnail h-24 w-24 object-cover rounded-lg shrink-0 border
                        cursor-pointer #{index == 0 ? 'ring-2 ring-black' : ''}",
                data: { image_url: url_for(main) } %>
            <% end %>
          <% end %>
        </div>

        <!-- 地図 -->
        <div class="mt-8 hidden sm:block" style="height:600px;">
          <% if @post.latitude.present? && @post.longitude.present? %>
            <%= render "posts/map", post: @post %>
          <% end %>
        </div>

      </div>
    <% end %>

    <!-- 右：テキスト -->
    <div class="sm:w-2/5 p-3 sm:p-6 rounded-2xl">

      <!-- タイトル -->
      <h1 class="py-4 text-xl sm:text-3xl font-normal text-stone-700 font-zenmaru
           inline
           bg-[linear-gradient(transparent_60%,_#7CFF6B_60%)]
           bg-no-repeat
           bg-[length:100%_0.75em]
           bg-[position:0_1.2em]
           [box-decoration-break:clone]
           [-webkit-box-decoration-break:clone]">
        <%= @post.title %>
      </h1>

      <!-- いいね + Xシェア -->
      <div class="flex items-center gap-6 mt-4">
        <% if current_user %>
          <div class="flex items-center gap-6">
            <%= render "likes/like", post: @post, show_count: true %>
          </div>
        <% end %>

        <%
        tweet_text = "#{@post.user.name}さんの旅の記録｜#{@post.title}｜Trip-let"
        tweet_url = request.original_url
        %>
        <%= link_to "https://twitter.com/intent/tweet?url=#{ERB::Util.url_encode(tweet_url)}&text=#{ERB::Util.url_encode(tweet_text)}&hashtags=旅行,旅の記録,旅行好きな人と繋がりたい,旅好き,風景写真",
                    target: "_blank",
                    rel: "noopener",
                    class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm
                            bg-black text-white rounded-lg hover:bg-gray-800 transition" do %>

          <svg aria-label="X logo"
               viewBox="0 0 300 271"
               class="w-4 h-4 fill-current">
            <path d="m236 0h46l-101 115 118 156h-92.6l-72.5-94.8-83 94.8h-46l107-123-113-148h94.9l65.5 86.6zm-16.1 244h25.5l-165-218h-27.4z"/>
          </svg>

          <span>Xでシェア</span>

        <% end %>
      </div>

      <!-- メタ情報 -->
      <div class="px-1 text-base sm:text-lg text-stone-600 font-zenmaru">
        <div class="flex items-center gap-6">
          <% if @post.visited_at.present? %>
            <div class="flex items-center gap-6">
              <span class="shrink-0">訪問日</span>
              <span><%= @post.visited_at %></span>
            </div>
          <% end %>

          <% if @post.duration.present? %>
            <div class="flex items-center gap-6">
              <span class="shrink-0">所要時間</span>
              <span><%= duration_label(@post.duration) %></span>
            </div>
          <% end %>
        </div>        

        <div class="flex items-center font-zenmaru">
          <span class="shrink-0 text-base sm:text-lg me-2">場所　➡</span>
          <span class="font-medium">
            <%= country_name(@post.country) %>

            <% if @post.country == "JP" && @post.prefecture.present? %>
              / <%= @post.prefecture %>
            <% end %>
            
            <% if @post.region.present? %>
              / <%= @post.region %>
            <% end %>
          </span>
        </div>
      </div>

      <div class="sm:overflow-auto sm:max-h-[90vh]">
        <!-- 感想・メモ -->
        <div class="py-1 px-1 text-base sm:text-xl text-stone-700
                    leading-[2.2rem] whitespace-pre-line font-zenmaru">
          <%= @post.body %>
        </div>

        <!-- 知っておくと便利 -->
        <% if @post.warning.present? %>
          <div class="ml-1 mt-3 pt-3 pb-3 px-3 bg-sky-50 rounded-2xl relative overflow-hidden">
            <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-sky-500"></div>

            <h2 class="flex items-center font-bold text-sky-600 text-base sm:text-xl tracking-wider uppercase mb-0">
              <span class="p-2">💡知っておくと便利</span> 
            </h2>
    
            <div class="w-full border-t border-sky-200 border-dotted"></div>
    
            <p class="whitespace-pre-line px-2 py-1 text-base sm:text-xl text-gray-700 leading-relaxed font-medium font-zenmaru">
              <%= @post.warning %>
            </p>
          </div>
        <% end %>
      </div>

      <!-- URL -->
      <% if @post.url.present? %>
        <div class="mt-6">
          <%= link_to @post.url,
              target: "_blank",
              rel: "noopener",
              class: "flex items-center gap-4 p-4 rounded-2xl
                      bg-white border border-gray-200
                      shadow-sm hover:shadow-md
                      hover:bg-gray-50 transition" do %>

            <!-- アイコン -->
            <div class="text-sky-500 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke-width="1.5"
                   stroke="currentColor"
                   class="w-6 h-6">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
              </svg>
            </div>

            <!-- テキスト -->
            <div class="flex flex-col">
              <span class="text-sm text-gray-500">
                関連サイト
              </span>

              <span class="text-sky-600 underline break-all">
                <%= @post.url %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- 投稿者情報 -->
      <%= link_to user_path(@post.user) do %>
        <div class="flex items-center mt-8 mb-6 ps-2 py-4 gap-3 border-y border-gray-200 bg-white hover:bg-gray-50 shadow-sm hover:shadow-md transition cursor-pointer">

          <!-- アバター -->
          <div class="h-12 w-12 rounded-full overflow-hidden bg-gray-100 flex items-center justify-center">
            <% if @post.user.avatar.attached? %>
              <%= image_tag @post.user.avatar,
                  class: "w-full h-full object-cover" %>
            <% else %>
              <svg xmlns="http://www.w3.org/2000/svg"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke-width="1.5"
                   stroke="currentColor"
                   class="w-6 h-6 text-gray-400">
                <path stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75
                         a7.488 7.488 0 0 0-5.982 2.975
                         m11.963 0a9 9 0 1 0-11.963 0
                         m11.963 0A8.966 8.966 0 0 1 12 21
                         a8.966 8.966 0 0 1-5.982-2.275
                         M15 9.75a3 3 0 1 1-6 0
                         3 3 0 0 1 6 0Z" />
              </svg>
            <% end %>
          </div>

          <!-- 名前 -->
          <div class="flex flex-col">
            <span class="font-semibold text-gray-800">
              <%= @post.user.name %>
            </span>
          </div>
        </div>
      <% end %>

      <!-- 地図 スマホのみ -->
      <div class="mt-8 hidden sm:hidden">
        <% if @post.latitude.present? && @post.longitude.present? %>
          <%= render "posts/map", post: @post %>
        <% end %>
      </div>

      <!-- 編集・削除ボタン(投稿者のみ) -->
      <% if user_signed_in? && current_user == @post.user %>
        <div class="flex flex-col gap-3">
          <%= link_to "編集", edit_post_path(@post),
              class: "w-full px-4 py-2 bg-sky-500 hover:bg-sky-400 text-center text-white rounded-lg" %>
          <%= link_to "削除", post_path(@post),
              method: :delete,
              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" },
              class: "w-full px-4 py-2 border-2 bg-gray-300 hover:bg-gray-400 hover:text-white text-center rounded-lg" %>
        </div>
      <% end %>
    </div>
  </div>
</div>


<script>
  document.addEventListener("turbo:load", () => {
    const mainImage = document.getElementById("main-image");
    if (!mainImage) return;

    const thumbnails = Array.from(document.querySelectorAll(".thumbnail"));
    if (thumbnails.length === 0) return;

    const prevBtn = document.getElementById("prev-image");
    const nextBtn = document.getElementById("next-image");

    let currentIndex = thumbnails.findIndex(t =>
      t.classList.contains("ring-2")
    );
    if (currentIndex === -1) currentIndex = 0;

    function preload(index) {
      if (!thumbnails[index]) return;
      const img = new Image();
      img.src = thumbnails[index].dataset.imageUrl;
    }

    function updateImage(index) {
      if (!thumbnails[index]) return;
      const thumbnail = thumbnails[index];
      mainImage.src = thumbnail.dataset.imageUrl;

      thumbnails.forEach(t =>
        t.classList.remove("ring-2", "ring-black")
      );
      thumbnail.classList.add("ring-2", "ring-black");

      currentIndex = index;

      // 次と前を先読み
      preload((index + 1) % thumbnails.length);
      preload((index - 1 + thumbnails.length) % thumbnails.length);
    }

    thumbnails.forEach((thumbnail, index) => {
      thumbnail.addEventListener("click", () => {
        updateImage(index);
      });
    });

    if (prevBtn) {
      prevBtn.addEventListener("click", () => {
        updateImage(
          currentIndex === 0 ? thumbnails.length - 1 : currentIndex - 1
        );
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener("click", () => {
        updateImage(
          currentIndex === thumbnails.length - 1 ? 0 : currentIndex + 1
        );
      });
    }

    // 初期表示時も先読み
    preload((currentIndex + 1) % thumbnails.length);
    preload((currentIndex - 1 + thumbnails.length) % thumbnails.length);
  });
</script>
