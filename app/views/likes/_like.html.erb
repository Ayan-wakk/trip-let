<% show_count ||= false %>
<%= turbo_frame_tag "like_post_#{post.id}" do %>
<% if user_signed_in? && post.liked_by?(current_user) %>
  <%= button_to post_like_path(post),
      method: :delete,
      class: "bg-white/90 rounded-full px-2 py-2 text-red-500 text-xl
              flex items-center justify-center
              hover:scale-105 hover:shadow-2xl transition" do %>

        <svg xmlns="http://www.w3.org/2000/svg" fill="red" viewBox="0 0 24 24"
             stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5
                   -1.935 0-3.597 1.126-4.312 2.733
                   -.715-1.607-2.377-2.733-4.313-2.733
                   C5.1 3.75 3 5.765 3 8.25
                   c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>

        <% if show_count %>
          <span class="ml-1"><%= post.likes.count %></span>
        <% end %>

  <% end %>

<% else %>

  <%= button_to post_like_path(post),
      method: :post,
      class: "bg-white/90 rounded-full px-2 py-2 text-red-500 text-xl
              flex items-center justify-center
              hover:scale-105 hover:shadow-2xl transition" do %>

        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
             stroke-width="1.5" stroke="currentColor" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5
                   -1.935 0-3.597 1.126-4.312 2.733
                   -.715-1.607-2.377-2.733-4.313-2.733
                   C5.1 3.75 3 5.765 3 8.25
                   c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>

        <% if show_count %>
          <span class="ml-1"><%= post.likes.count %></span>
        <% end %>

  <% end %>

  <% end %>

<% end %>